{
    "name": "agent/agent",
    "description": "AI Agent Framework",
    "type": "project",
    "require": {
        "php": "^8.2",
        "cboden/ratchet": "^0.4.4",
        "crwlr/html-2-text": "^0.1.2",
        "guzzlehttp/guzzle": "^7.9",
        "laravel-zero/framework": "^10.4",
        "nunomaduro/termwind": "^1.15",
        "openai-php/laravel": "^0.10",
        "react/event-loop": "^1.5",
        "react/http": "^1.10",
        "react/socket": "^1.16",
        "react/stream": "^1.4",
        "symfony/routing": "^6.4",
        "webklex/laravel-imap": "^5.3"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^8.26",
        "pestphp/pest": "^2.36",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "exclude-from-classmap": [
            "vendor/laravel/framework/src/Illuminate/Foundation/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "exclude-from-classmap": [
            "tests/Unit/ToolTest.php",
            "tests/Unit/AgentToolSchemaTest.php",
            "tests/FollowUpRecognitionTest.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["agent"]
}
